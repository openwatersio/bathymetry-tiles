# CHS NONNA-100 (Canada, 100 m) — Chart Datum bathymetry. Run from pipelines/:  just ../sources/nonna_100/
# No static URLs: source_download_nonna harvests tiles via the public guest API for a BBOX
# (defaults to Canada's extent; the feature query returns only surveyed tiles, so the harvest
# is patchy, not a full grid). EPSG:4326; values are elevation on Chart Datum (seafloor
# negative, like GEBCO) → no datum transform. RepresentationLevel 2 = NONNA 100 m.
[no-cd]
default:
    BBOX="${BBOX:--141,41,-53,84}" uv run python source_download_nonna.py nonna_100
    uv run python source_normalize.py nonna_100 --crs EPSG:4326
    uv run python source_bounds.py nonna_100
    uv run python source_polygonize.py nonna_100 8
    uv run python source_create_tarball.py nonna_100
