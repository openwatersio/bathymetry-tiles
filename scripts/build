#!/usr/bin/env bash
# Run the full GEBCO → tile pipeline.
#
# Usage:
#   ./scripts/build                        # full global
#   BBOX="-85,20,-70,35" ./scripts/build   # Bahamas (regional extract)
#
# Environment variables:
#   BBOX        Bounding box "west,south,east,north" (empty = global)
#   MAX_ZOOM    Maximum contour tile zoom level (default: 9)
#   THREADS     Parallel processing threads (default: nproc)
#   FORCE       Set to 1 to rebuild all cached files

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/config.sh"

SUFFIX="${BBOX:+_${BBOX}}"

echo "╔══════════════════════════════════════════════════════════╗"
echo "║  GEBCO → Tiles Pipeline                                 ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

# Step 1: Download & clip (global if BBOX is empty).
echo "── Step 1: Download GEBCO data ─────────────────────────────"
INPUT_TIF=$("${SCRIPT_DIR}/download")
echo ""

# Step 2: Terrain-RGB tiles. Each step is self-contained and writes its own
# PMTiles to output/ — the CI workflow runs terrain and contour as separate jobs.
echo "── Step 2: Build Terrain-RGB tiles ───────────────────────────"
"${SCRIPT_DIR}/terrain" "${INPUT_TIF}"
echo ""

# Step 3: Contour vector tiles.
echo "── Step 3: Generate contour tiles ────────────────────────────"
"${SCRIPT_DIR}/contour" "${INPUT_TIF}"

echo ""
echo "═══ Pipeline complete ═══"
log "  Terrain: ${OUTPUT_DIR}/terrain${SUFFIX}.pmtiles"
log "  Contours: ${OUTPUT_DIR}/contours${SUFFIX}.pmtiles"
